# Configurações de Produção - Grupo Cisne

# --- IA & QUALIFICAÇÃO ---
# Chave da OpenRouter (obrigatória para o chat de qualificação)
NEXT_PUBLIC_OPENROUTER_API_KEY=sua_chave_aqui

# --- API DO DASHBOARD (Digital Ocean) ---
# URL base do backend — sem barra no final
NEXT_PUBLIC_API_URL=https://api.grupocisne.com.br

# --- CONTATO & WHATSAPP ---
# Número de WhatsApp no formato internacional: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=5511000000000

# --- DEPLOY & SSL ---
# E-mail para registro do certificado SSL via Let's Encrypt (Traefik)
LETSENCRYPT_EMAIL=seuemail@grupocisne.com.br

# Domínio principal do site
DOMAIN_NAME=grupocisne.com.br

# --- SISTEMA (Next.js) ---
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
PORT=8080
